# 复制为本地配置：cp .env.example .env
# 切勿将含真实密钥的 .env 提交到仓库（已在 .gitignore 中忽略 .env）

# Ollama 服务根地址（可带或不带末尾 /，程序会自动去掉；不要在此处写 API 路径）
OLLAMA_URL=http://127.0.0.1:11434

# 本代理监听地址 host:port
BIND_ADDR=127.0.0.1:5000

# 为 1/true/yes/on 时：无论 Langfuse 是否成功，每条请求与响应都写本地审计日志（target: ollama_audit）
# AUDIT_LOG_ALWAYS=false

# 滚动日志目录（默认 logs/）、周期 daily / hourly / minutely；仅写文件不写控制台时设 LOG_DISABLE_STDOUT=true
# LOG_DIR=logs
# LOG_ROTATION=daily
# LOG_DISABLE_STDOUT=false

# Langfuse：公钥与私钥都非空时才会上报；自建实例请改 LANGFUSE_BASE_URL
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
