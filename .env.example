# 复制为本地配置：cp .env.example .env
# 切勿将含真实密钥的 .env 提交到仓库（已在 .gitignore 中忽略 .env）

# LLM 服务根地址（可带或不带末尾 /，程序会自动去掉；不要在此处写 API 路径）
LLM_URL=http://127.0.0.1:11434

# 本代理监听地址 host:port
BIND_ADDR=127.0.0.1:5000

# 同时设置以下两项且非空时，在 BIND_ADDR 上启用 HTTPS（PEM 证书与私钥路径）；未设置则仍为 HTTP
# TLS_CERT_PATH=/path/to/fullchain.pem
# TLS_KEY_PATH=/path/to/privkey.pem

# 上游与 Langfuse 共用 HTTP 超时（秒）；流式场景须覆盖整条流；0=不设超时
# HTTP_CLIENT_TIMEOUT_SECS=600

# 为 1/true/yes/on 时：对每条经代理转发的 LLM 请求与响应写入本地审计日志文件（target: llm_audit），与 Langfuse 是否成功无关
# AUDIT_LOG_ENABLE=false

# 审计日志中 input/output JSON 的最大 UTF-8 字节数；0=不截断（完整写入）；默认 16384
# AUDIT_LOG_MAX_CHARS=16384

# 滚动日志目录（默认 logs/）、周期 daily / hourly / minutely；仅写文件不写控制台时设 LOG_DISABLE_STDOUT=true
# LOG_DIR=logs
# LOG_ROTATION=daily
# LOG_DISABLE_STDOUT=false

# Langfuse：公钥与私钥都非空时才会上报；设为 0/false/no/off 可关闭写入（保留密钥）
# LANGFUSE_ENABLE=false
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
